      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Alice Tenant\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"Password123!\",\n  \"organizationName\": \"Acme Properties\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "if (response.token) pm.environment.set('authToken', response.token);",
              "if (response.refreshToken) pm.environment.set('refreshToken', response.refreshToken);",
              "if (response.organization && response.organization.id) pm.environment.set('organizationId', response.organization.id);",
              "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });"
            ]
          }
        }
      ]
    },
