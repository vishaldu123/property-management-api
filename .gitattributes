# Normalize line endings to LF in repository
# Windows developers will have CRLF in working directory (set via core.autocrlf)
# but repository always has LF

# Auto detect text files and normalize line endings to LF
* text=auto

# Explicitly mark text files
*.ts text
*.js text
*.json text
*.md text
*.yml text
*.yaml text
*.toml text
*.env* text
*.sql text

# Shell scripts - always LF
*.sh text eol=lf

# Batch files - always CRLF (Windows only)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files - no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.zip binary
*.gz binary
*.tar binary
