generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core Models for Phase 1: Foundation

model Organization {
  id              String             @id @default(uuid())
  name            String
  slug            String             @unique
  email           String             @unique
  phone           String?
  website         String?
  logo            String?
  address         String?
  city            String?
  state           String?
  country         String?
  postalCode      String?
  timezone        String?            @default("UTC")
  currency        String?            @default("USD")
  subscriptionPlan   String          @default("FREE")
  subscriptionStatus String          @default("TRIAL")
  isActive        Boolean            @default(true)
  description     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?
  users           OrganizationUser[]
  invitations     OrganizationInvitation[]
  roles           Role[]
  permissions     Permission[]
  userRoles       UserRole[]         @relation(name: "UserRoles")
  settings        OrganizationSettings?
  branding        OrganizationBranding?
  preferences     OrganizationPreferences?
  properties      Property[]         @relation("OrganizationProperties")
  units           Unit[]             @relation("OrganizationUnits")
  tenants         Tenant[]           @relation("OrganizationTenants")
  leases          Lease[]            @relation("OrganizationLeases")

  @@index([deletedAt])
  @@index([createdBy])
  @@index([isActive])
}

// Organization Settings (Sprint 3)

model OrganizationSettings {
  id              String             @id @default(uuid())
  organizationId  String             @unique
  timezone        String             @default("UTC")
  currency        String             @default("USD")
  dateFormat      String             @default("YYYY-MM-DD")
  timeFormat      String             @default("HH:mm:ss")
  language        String             @default("en")
  measurementUnit String             @default("metric")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdBy       String?
  updatedBy       String?

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// Organization Branding (Sprint 3)

model OrganizationBranding {
  id              String             @id @default(uuid())
  organizationId  String             @unique
  logoUrl         String?
  logoAltText     String?
  faviconUrl      String?
  primaryColor    String             @default("#000000")
  secondaryColor  String             @default("#FFFFFF")
  accentColor     String             @default("#0066CC")
  theme           String             @default("light")
  customCss       String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdBy       String?
  updatedBy       String?

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// Organization Preferences (Sprint 3)

model OrganizationPreferences {
  id              String             @id @default(uuid())
  organizationId  String             @unique
  emailNotifications Boolean          @default(true)
  emailDigest     String             @default("daily")
  twoFactorAuth   Boolean            @default(false)
  dataRetention   Int                @default(90)
  backupFrequency String             @default("weekly")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdBy       String?
  updatedBy       String?

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model User {
  id              String             @id @default(uuid())
  name            String
  email           String             @unique
  password        String
  phone           String?
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?
  memberships     OrganizationUser[]
  userRoles       UserRole[]         @relation(name: "UserRoles")
  refreshTokens   RefreshToken[]
  passwordResets  PasswordResetToken[]

  @@index([deletedAt])
  @@index([createdBy])
}

// Organization User (Sprint 3.1 - Organization Membership)
model OrganizationUser {
  id              String             @id @default(uuid())
  organizationId  String
  userId          String
  role            String             @default("MEMBER")
  status          String             @default("ACTIVE") // ACTIVE, INVITED, SUSPENDED, REMOVED
  isOwner         Boolean            @default(false)
  joinedAt        DateTime           @default(now())
  suspendedAt     DateTime?
  suspendedReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?
  
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitations     OrganizationInvitation[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([isOwner])
  @@index([deletedAt])
}

// Organization Invitation (Sprint 3.1 - Invitation Lifecycle)
model OrganizationInvitation {
  id              String             @id @default(uuid())
  organizationId  String
  organizationUserId String?          // Null until invitation accepted
  email           String
  invitedBy       String
  token           String             @unique
  status          String             @default("PENDING") // PENDING, ACCEPTED, REJECTED, EXPIRED, CANCELLED
  expiresAt       DateTime
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  cancelledAt     DateTime?
  sentCount       Int                @default(1)
  lastSentAt      DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationUser OrganizationUser?  @relation(fields: [organizationUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, email, status])
  @@index([organizationId])
  @@index([email])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
}

// RBAC Models (prepared for Phase 2)

model Role {
  id              String             @id @default(uuid())
  organizationId  String
  name            String
  key             String
  description     String?
  isDefault       Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?
  
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions     RolePermission[]
  userRoles       UserRole[]         @relation(name: "UserRoles")

  @@unique([organizationId, key])
  @@index([organizationId])
  @@index([deletedAt])
}

model Permission {
  id              String             @id @default(uuid())
  organizationId  String
  key             String
  name            String
  description     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?
  
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roles           RolePermission[]

  @@unique([organizationId, key])
  @@index([organizationId])
  @@index([deletedAt])
}

model RolePermission {
  id              String             @id @default(uuid())
  roleId          String
  permissionId    String
  createdAt       DateTime           @default(now())
  
  role            Role               @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission      Permission         @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@index([roleId])
}

// User Role Assignment (Maps users to roles within an organization)
model UserRole {
  id              String             @id @default(uuid())
  organizationId  String
  userId          String
  roleId          String
  assignedAt      DateTime           @default(now())
  assignedBy      String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  
  organization    Organization       @relation(name: "UserRoles", fields: [organizationId], references: [id], onDelete: Cascade)
  user            User               @relation(name: "UserRoles", fields: [userId], references: [id], onDelete: Cascade)
  role            Role               @relation(name: "UserRoles", fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, roleId])
  @@index([organizationId])
  @@index([userId])
  @@index([roleId])
  @@index([deletedAt])
}

// Authentication Token Models (for refresh token rotation and password reset)

model RefreshToken {
  id              String             @id @default(uuid())
  userId          String
  token           String             @unique
  expiresAt       DateTime
  isRevoked       Boolean            @default(false)
  createdAt       DateTime           @default(now())
  
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id              String             @id @default(uuid())
  userId          String
  token           String             @unique
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime           @default(now())
  
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([expiresAt])
}

// Property Model (Sprint 5)
model Property {
  id              String             @id @default(uuid())
  organizationId  String
  name            String
  code            String             // Property identifier code
  description     String?
  propertyType    String             // Apartment, Villa, Commercial, etc.
  status          String             @default("DRAFT") // DRAFT, ACTIVE, INACTIVE, ARCHIVED
  address         String
  city            String
  state           String
  country         String
  postalCode      String
  latitude        Decimal?
  longitude       Decimal?
  timezone        String             @default("UTC")
  totalUnits      Int?               // Number of units in the property
  yearBuilt       Int?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?          // Soft delete
  createdBy       String?
  updatedBy       String?
  
  organization    Organization       @relation("OrganizationProperties", fields: [organizationId], references: [id], onDelete: Cascade)
  units           Unit[]              @relation("PropertyUnits")
  leases          Lease[]             @relation("PropertyLeases")
  
  // Indexes for common queries
  @@unique([organizationId, code]) // Code must be unique per organization
  @@index([organizationId])
  @@index([status])
  @@index([propertyType])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([createdBy])
  // Full-text search indexes
  @@index([name])
  @@index([city])
  @@index([country])
}

// Unit model - represents individual units/apartments within a property
model Unit {
  id                String             @id @default(uuid())
  propertyId        String             // Property this unit belongs to
  organizationId    String             // Organization for tenant isolation (denormalized for efficiency)
  unitNumber        String             // Unit number/identifier (e.g., 101, A-102, etc.)
  name              String?            // Optional unit name/title
  floor             Int?               // Floor number
  block             String?            // Building/Block identifier
  unitType          String             @default("Apartment") // Studio, Apartment, Villa, Office, Shop, Warehouse, Parking, Storage
  status            String             @default("Available") // Available, Occupied, Reserved, Under Maintenance, Inactive
  bedrooms          Int?               // Number of bedrooms
  bathrooms        Int?               // Number of bathrooms
  area              Decimal?           // Unit area/size
  areaUnit          String             @default("sqft") // Unit of measurement (sqft, sqm, etc.)
  rentAmount        Decimal?           // Monthly rent amount
  securityDeposit   Decimal?           // Security deposit amount
  availabilityDate  DateTime?          // When unit becomes available for rent/sale
  notes             String?            // Additional notes
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?          // Soft delete
  createdBy         String?
  updatedBy         String?
  
  property          Property           @relation("PropertyUnits", fields: [propertyId], references: [id], onDelete: Cascade)
  organization      Organization       @relation("OrganizationUnits", fields: [organizationId], references: [id], onDelete: Cascade)
  tenants           Tenant[]           @relation("UnitTenants")
  leases            Lease[]            @relation("UnitLeases")
  
  // Indexes for common queries
  @@unique([propertyId, unitNumber]) // Unit number must be unique per property
  @@index([propertyId])
  @@index([organizationId])
  @@index([status])
  @@index([unitType])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([createdBy])
  @@index([floor])
  // Search indexes
  @@index([name])
  @@index([block])
}

// Tenant Model (Sprint 7)
model Tenant {
  id                    String             @id @default(uuid())
  organizationId        String             // Organization this tenant belongs to
  unitId                String?            // Optional: Unit this tenant is associated with
  firstName             String             // First name
  lastName              String             // Last name
  email                 String             // Email address
  phone                 String?            // Phone number
  dateOfBirth           DateTime?          // Date of birth
  governmentIdType      String?            // ID type (Passport, Driver License, National ID, etc.)
  governmentIdNumber    String?            // ID number
  emergencyContactName  String?            // Emergency contact name
  emergencyContactPhone String?            // Emergency contact phone
  occupation            String?            // Occupation
  employer              String?            // Employer name
  status                String             @default("Prospect") // Prospect, Active, Notice, Former, Blacklisted
  notes                 String?            // Additional notes
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  deletedAt             DateTime?          // Soft delete
  createdBy             String?
  updatedBy             String?
  
  organization          Organization      @relation("OrganizationTenants", fields: [organizationId], references: [id], onDelete: Cascade)
  unit                  Unit?              @relation("UnitTenants", fields: [unitId], references: [id], onDelete: SetNull)
  leases                Lease[]            @relation("TenantLeases")
  
  // Indexes for common queries
  @@unique([organizationId, email]) // Email unique per organization
  @@index([organizationId])
  @@index([unitId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([createdBy])
  @@index([firstName])
  @@index([lastName])
  @@index([phone])
}

// Lease Model (Sprint 8)
model Lease {
  id                String             @id @default(uuid())
  organizationId    String             // Organization this lease belongs to
  propertyId        String             // Property this lease is for
  unitId            String             // Unit this lease is for
  tenantId          String             // Tenant this lease is for
  leaseNumber       String             // Lease identifier/number
  startDate         DateTime           // Lease start date
  endDate           DateTime           // Lease end date
  moveInDate        DateTime?          // Actual move-in date
  moveOutDate       DateTime?          // Actual move-out date
  monthlyRent       Decimal            // Monthly rent amount
  securityDeposit   Decimal            // Security deposit amount
  billingCycle      String             @default("monthly") // monthly, quarterly, annual
  gracePeriod       Int                @default(0) // Grace period in days
  status            String             @default("Draft") // Draft, Pending, Active, Expired, Terminated, Renewed
  renewalOption     Boolean            @default(false) // Whether renewal is available
  autoRenewal       Boolean            @default(false) // Auto-renew on expiry
  noticePeriod      Int                @default(30) // Notice period in days for termination
  notes             String?            // Additional notes
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?          // Soft delete
  createdBy         String?
  updatedBy         String?
  
  organization      Organization      @relation("OrganizationLeases", fields: [organizationId], references: [id], onDelete: Cascade)
  property          Property           @relation("PropertyLeases", fields: [propertyId], references: [id], onDelete: Cascade)
  unit              Unit               @relation("UnitLeases", fields: [unitId], references: [id], onDelete: Cascade)
  tenant            Tenant             @relation("TenantLeases", fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Indexes for common queries
  @@index([organizationId])
  @@index([propertyId])
  @@index([unitId])
  @@index([tenantId])
  @@index([status])
  @@index([leaseNumber])
  @@index([startDate])
  @@index([endDate])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([createdBy])
  @@index([autoRenewal])
}


