# Application Configuration
NODE_ENV=development
PORT=5000
LOG_LEVEL=INFO
APP_NAME=Property Management API
APP_VERSION=1.0.0

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/property_management

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
# For production, set specific origin URLs (e.g., https://app.example.com,https://admin.example.com)
# For development, can be * or specific localhost URLs
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Security Configuration
BCRYPT_ROUNDS=12
SECURE_COOKIES=true
TRUST_PROXY=true

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=3600000
PASSWORD_RESET_RATE_LIMIT_MAX_REQUESTS=3

# Brute Force Protection
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_LOCKOUT_DURATION_MS=1800000
BRUTE_FORCE_ATTEMPT_WINDOW_MS=900000

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Email Configuration
EMAIL_PROVIDER=sendgrid
EMAIL_FROM_ADDRESS=noreply@propertymanagement.com
SENDGRID_API_KEY=your-sendgrid-api-key

# Payment Configuration
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
